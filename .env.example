# Support Triage Agent Configuration
# Copy this file to .env and fill in your API keys
# The .env file is already in .gitignore (won't be committed)

# Claude API Key - Required for Phase 4 (LLM Reasoning)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override data directory (default: data)
# DATA_DIR=data

# Optional: Override support tickets directory (default: support_tickets)
# TICKETS_DIR=support_tickets
